rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    function isAdmin() { 
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (request.auth.token.email == "tklee3523@gmail.com" && request.auth.token.email_verified == true)
      ); 
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Validation for Project (The Blueprint)
    function isValidProject(data) {
      return data.keys().hasAll(['id', 'title', 'description', 'category', 'thumbnail', 'link', 'tags'])
        && data.keys().size() == 7
        && data.id is string && data.id.size() <= 128
        && data.title is string && data.title.size() <= 200
        && data.description is string && data.description.size() <= 2000
        && data.category in ['creative', 'journalist', 'motion']
        && data.thumbnail is string && data.thumbnail.size() <= 1000
        && data.link is string && data.link.size() <= 1000
        && data.tags is list && data.tags.size() <= 20;
    }

    // --- Rules ---

    // 1. Projects: Publicly readable, admin editable
    match /projects/{projectId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProject(incoming()) && incoming().id == projectId && isValidId(projectId);
      allow update: if isAdmin() && isValidProject(incoming()) && incoming().id == existing().id;
      allow delete: if isAdmin();
    }

    // 2. Admins: Users can check their own admin status
    match /admins/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow write: if isAdmin(); // Only admins can grant admin rights
    }
    
    // 3. Test collection for connection check
    match /test/connection {
      allow read: if true;
    }
  }
}
