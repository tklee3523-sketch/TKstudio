{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A portfolio project item",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string", "enum": ["creative", "journalist", "motion"] },
        "thumbnail": { "type": "string" },
        "link": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "title", "description", "category", "thumbnail", "link", "tags"]
    },
    "Admin": {
      "title": "Admin",
      "description": "Admin user record",
      "type": "object",
      "properties": {
        "email": { "type": "string" }
      },
      "required": ["email"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "The collection of portfolio projects"
    },
    "/admins/{uid}": {
      "schema": "Admin",
      "description": "List of authorized admin UIDs"
    }
  }
}
